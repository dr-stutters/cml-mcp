# Copy to .env and fill in your CML server details
CML_URL=https://cml.example.com
CML_USERNAME=admin
CML_PASSWORD=changeme
# CML uses a self-signed certificate by default
CML_VERIFY_SSL=false
# Request timeout in seconds
CML_TIMEOUT=60

# Firepower Management Center (FMC), for the companion `fmc` MCP server
# (../Firepower_MCP, registered in .mcp.json; used by the firewall-engineer agent).
# The fmc server reads these as env vars, or from ../Firepower_MCP/.env.
FMC_URL=https://192.0.2.11
FMC_USERNAME=admin
FMC_PASSWORD=changeme
FMC_DOMAIN=Global
FMC_VERIFY_SSL=false
FMC_TIMEOUT=60

# Cisco Identity Services Engine (ISE), for the companion `ise` MCP server
# (../ISE_MCP, registered in .mcp.json; used by the ise-engineer agent).
# The ise server reads these as env vars, or from ../ISE_MCP/.env.
ISE_URL=https://192.0.2.30
ISE_USERNAME=admin
ISE_PASSWORD=changeme
ISE_ERS_PORT=9060
ISE_VERIFY_SSL=false
ISE_TIMEOUT=60
