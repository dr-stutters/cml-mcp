# =====================================================================
# MCP suite - shared secrets template.
#
# This one file documents every companion server's variables. Two ways to use it:
#   1. Suite-wide (recommended): copy to ../.env - one level ABOVE the repos
#      (i.e. /path/to/MCP/.env). Every MCP server in the suite reads that shared
#      file as a base, so lab credentials live in ONE place.
#   2. Per-repo: copy the relevant block into an individual repo's own .env.
#
# Precedence (highest wins):  process env  >  <repo>/.env  >  shared ../.env
# So a per-repo .env still overrides the shared file when you need it to.
# Never commit any .env - all six repos gitignore it.
# =====================================================================

# Cisco Modeling Labs (CML) - the `cml` MCP server (this repo).
CML_URL=https://cml.example.com
CML_USERNAME=admin
CML_PASSWORD=changeme
# CML uses a self-signed certificate by default
CML_VERIFY_SSL=false
# Request timeout in seconds
CML_TIMEOUT=60

# Firepower Management Center (FMC), for the companion `fmc` MCP server
# (../Firepower_MCP, registered in .mcp.json; used by the firewall-engineer agent).
# The fmc server reads these as env vars, or from ../Firepower_MCP/.env.
FMC_URL=https://192.0.2.11
FMC_USERNAME=admin
FMC_PASSWORD=changeme
FMC_DOMAIN=Global
FMC_VERIFY_SSL=false
FMC_TIMEOUT=60

# Cisco Identity Services Engine (ISE), for the companion `ise` MCP server
# (../ISE_MCP, registered in .mcp.json; used by the ise-engineer agent).
# The ise server reads these as env vars, or from ../ISE_MCP/.env.
ISE_URL=https://192.0.2.30
ISE_USERNAME=admin
ISE_PASSWORD=changeme
# ERS over 443 (modern); legacy 9060 is deprecated/often off. ERS must be enabled
# in the ISE GUI (Admin > System > Settings > API Settings).
ISE_ERS_PORT=443
ISE_VERIFY_SSL=false
ISE_TIMEOUT=60
ISE_RETRIES=2

# Windows Server (WinRM), for the companion `windows` MCP server (../Windows_MCP,
# registered in .mcp.json; used by the windows-engineer agent). The windows
# server reads these as env vars, or from ../Windows_MCP/.env. Enable WinRM on the
# server first: Enable-PSRemoting -Force
WINRM_HOST=192.0.2.50
WINRM_USERNAME=Administrator
WINRM_PASSWORD=changeme
WINRM_AUTH=ntlm
WINRM_SSL=false
WINRM_PORT=5985
WINRM_CERT_VALIDATION=false
WINRM_TIMEOUT=120

# Splunk Enterprise, for the companion `splunk` MCP server (../Splunk_MCP,
# registered in .mcp.json; used by the splunk-engineer agent). The splunk server
# reads these as env vars, or from ../Splunk_MCP/.env. Management/REST API on 8089
# (Basic auth); HEC on 8088 (token). If the port is omitted, :8089 is assumed.
SPLUNK_URL=https://192.0.2.51:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
# HEC (optional): derived from SPLUNK_URL host with :8088 unless set explicitly.
# SPLUNK_HEC_URL=https://192.0.2.51:8088
# SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
SPLUNK_VERIFY_SSL=false
SPLUNK_TIMEOUT=60
SPLUNK_RETRIES=2

# Catalyst 9800 WLC (RESTCONF), for the companion `wlc` MCP server (../WLC_MCP,
# registered in .mcp.json; used by the wireless-engineer agent). The wlc server
# reads these as env vars, or from ../WLC_MCP/.env. Enable on the C9800: aaa
# new-model + a priv-15 local user + ip http secure-server + restconf.
WLC_URL=https://192.0.2.70
WLC_USERNAME=admin
WLC_PASSWORD=changeme
WLC_VERIFY_SSL=false
WLC_TIMEOUT=60
WLC_RETRIES=2
