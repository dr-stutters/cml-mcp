<form version="1.1" theme="dark">
  <label>SDA SOC / NOC Overview — single pane</label>
  <description>Wall board stitching the SD-Access + ISE + Firewall stack: NGFW allow/deny + TLS decryption (index=network, FTDv 198.18.128.82), identity/RADIUS auth (index=ise), and fabric syslog volume. One glance across the whole lab.</description>
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="tp">
      <label>Time range</label>
      <default><earliest>-24h@h</earliest><latest>now</latest></default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>FW Allowed</title>
      <single><search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430002" "AccessControlRuleAction: Allow" | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search><option name="rangeColors">["0x53a051","0x53a051"]</option></single>
    </panel>
    <panel>
      <title>FW Blocked (threats)</title>
      <single><search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430002" "AccessControlRuleAction: Block" | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search><option name="colorBy">value</option><option name="rangeColors">["0xdc4e41","0xdc4e41"]</option><option name="useColors">1</option></single>
    </panel>
    <panel>
      <title>TLS Decrypted</title>
      <single><search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430003" "SSLActualAction: Decrypt (Resign)" | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search><option name="rangeColors">["0x006d9c","0x006d9c"]</option></single>
    </panel>
    <panel>
      <title>ISE Auth Passed</title>
      <single><search><query><![CDATA[index=ise "CISE_Passed_Authentications" | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search><option name="rangeColors">["0x53a051","0x53a051"]</option></single>
    </panel>
    <panel>
      <title>ISE Auth Failed</title>
      <single><search><query><![CDATA[index=ise "CISE_Failed_Authentications" | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search><option name="colorBy">value</option><option name="rangeColors">["0xf8be34","0xdc4e41"]</option><option name="rangeValues">[0]</option><option name="useColors">1</option></single>
    </panel>
    <panel>
      <title>Fabric syslog events</title>
      <single><search><query><![CDATA[index=network | stats count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search></single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Firewall connections over time (allow / block)</title>
      <chart>
        <search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430002" | rex "AccessControlRuleAction: (?<action>\w+)" | timechart span=10m count by action]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
        <option name="charting.chart">column</option><option name="charting.chart.stackMode">stacked</option>
        <option name="charting.fieldColors">{"Allow":0x53a051,"Block":0xdc4e41}</option><option name="charting.legend.placement">bottom</option>
      </chart>
    </panel>
    <panel>
      <title>ISE authentications over time (passed / failed)</title>
      <chart>
        <search><query><![CDATA[index=ise ("CISE_Passed_Authentications" OR "CISE_Failed_Authentications") | rex "CISE_(?<isetype>Passed_Authentications|Failed_Authentications)" | eval result=if(isetype=="Passed_Authentications","Passed","Failed") | timechart span=30m count by result]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
        <option name="charting.chart">column</option><option name="charting.chart.stackMode">stacked</option>
        <option name="charting.fieldColors">{"Passed":0x53a051,"Failed":0xdc4e41}</option><option name="charting.legend.placement">bottom</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Firewall — blocked connections (threats)</title>
      <table>
        <search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430002" "AccessControlRuleAction: Block" | rex "SrcIP: (?<src>[^,]+)" | rex "DstIP: (?<dst>[^,]+)" | rex "AccessControlRuleName: (?<rule>[^,]+)" | rex "User: (?<user>[^,]+)" | eval user=coalesce(user,"-") | table _time user src dst rule | sort -_time | head 15]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
      </table>
    </panel>
    <panel>
      <title>Identity — top authenticated users</title>
      <table>
        <search><query><![CDATA[index=ise "CISE_Passed_Authentications" | rex "UserName=(?<user>[^,]+)" | search user=* | stats count as auths by user | sort -auths | head 10]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
      </table>
    </panel>
    <panel>
      <title>Identity — top network devices (NADs)</title>
      <table>
        <search><query><![CDATA[index=ise ("CISE_Passed_Authentications" OR "CISE_RADIUS_Accounting") | rex "NetworkDeviceName=(?<nad>[^,]+)" | search nad=* | stats count by nad | sort -count | head 10]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Fabric syslog volume by device</title>
      <chart>
        <search><query><![CDATA[index=network | stats count by host | sort -count]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
        <option name="charting.chart">bar</option>
      </chart>
    </panel>
    <panel>
      <title>Firewall — traffic by TrustSec SGT</title>
      <chart>
        <search><query><![CDATA[index=network host=198.18.128.82 "%FTD-6-430002" | rex "SourceSecurityGroup: (?<sgt>[^,]+)" | search sgt=* | stats count by sgt]]></query><earliest>$tp.earliest$</earliest><latest>$tp.latest$</latest></search>
        <option name="charting.chart">pie</option>
      </chart>
    </panel>
  </row>
</form>
